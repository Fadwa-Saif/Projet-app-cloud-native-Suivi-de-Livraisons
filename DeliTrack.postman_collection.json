      "name": "1. Register client",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Client created', function () { const json = pm.response.json(); pm.expect(json).to.have.property('email', 'alice@example.com'); });",
              "pm.collectionVariables.set('client_id', pm.response.json()._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:4002/auth/register", "protocol": "http", "host": ["localhost"], "port": "4002", "path": ["auth", "register"] },
        "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"role\": \"client\",\n  \"mot_passe\": \"pass123\"\n}" }
      }
